generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String
  pin       String   @unique
  createdAt DateTime @default(now())
  videos    Video[]
  bookings  CoachingSlot[]
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  contacted Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  url         String
  category    String
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  createdAt   DateTime @default(now())
}

model CoachingSlot {
  id          Int       @id @default(autoincrement())
  date        DateTime    // Session date and time
  duration    Int       @default(60) // minutes
  status      String    @default("available") // available, booked, confirmed, cancelled, completed
  studentId   Int?
  student     Student?  @relation(fields: [studentId], references: [id])
  notes       String?
  createdAt   DateTime  @default(now())
}