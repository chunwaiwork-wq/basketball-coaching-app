generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("student") // "student" or "coach"
  createdAt DateTime @default(now())
  bookings  CoachingSlot[]
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String
  pin       String   @unique
  userId    Int?     @unique   // Link to User account
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  videos    Video[]
  bookings  CoachingSlot[] // used when booking without User link
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  contacted Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  url         String
  category    String
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  createdAt   DateTime @default(now())
}

model CoachCalendar {
  id           Int      @id @default(autoincrement())
  refreshToken String
  email        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CoachingSlot {
  id              Int       @id @default(autoincrement())
  date            DateTime    // Session date and time
  duration        Int       @default(60) // minutes
  status          String    @default("available") // available, booked, confirmed, cancelled, completed
  studentId       Int?
  student         Student?  @relation(fields: [studentId], references: [id])
  userId          Int?
  user            User?     @relation(fields: [userId], references: [id])
  notes           String?
  googleEventId   String?   // Google Calendar event ID
  googleEventLink String?   // Link to Google Calendar event
  createdAt       DateTime  @default(now())
}